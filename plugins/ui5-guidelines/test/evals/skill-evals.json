{
  "version": "1.0.0",
  "description": "Manual evaluation test cases for skill quality assessment",
  "note": "These are reference test cases for manual evaluation with Claude Code",
  "evals": [
    {
      "id": "bp-001",
      "skill": "ui5-best-practices",
      "prompt": "Show me how to detect UI5 version at runtime and use IAsyncContentCreation if version >= 1.90.0",
      "expected_behavior": [
        "Uses VersionInfo.load() API",
        "Provides Component.ts example with IAsyncContentCreation interface",
        "Mentions version >= 1.90.0 requirement",
        "Code example is TypeScript-compatible"
      ]
    },
    {
      "id": "bp-002",
      "skill": "ui5-best-practices",
      "prompt": "I have an XML view with a button. How do I pass the button's text to my controller method when clicked?",
      "expected_behavior": [
        "Shows $source special model usage",
        "Provides XML example with press handler",
        "Explains parameter binding syntax"
      ]
    },
    {
      "id": "bp-003",
      "skill": "ui5-best-practices",
      "prompt": "What CSP directives do I need for a UI5 app with sap.ui.richtexteditor?",
      "expected_behavior": [
        "References CSP directive table",
        "Mentions 'unsafe-eval' requirement for richtexteditor",
        "Suggests Report-Only testing first"
      ]
    },
    {
      "id": "ts-001",
      "skill": "ui5-typescript-expert",
      "prompt": "Convert this controller to TypeScript with proper event types for UI5 1.115+",
      "expected_behavior": [
        "Checks UI5 version >= 1.115.0",
        "Imports control-specific event types (Button$PressEvent)",
        "Shows proper event handler signatures",
        "Explains version-conditional pattern"
      ]
    },
    {
      "id": "ts-002",
      "skill": "ui5-typescript-expert",
      "prompt": "I'm converting a custom control to TypeScript. How do I handle the metadata?",
      "expected_behavior": [
        "Shows MetadataOptions interface usage",
        "Explains runtime-generated methods",
        "Covers property/aggregation/event type safety",
        "Preserves JSDoc comments"
      ]
    },
    {
      "id": "ic-001",
      "skill": "ui5-integration-cards",
      "prompt": "Create an analytical card with a donut chart showing sales by region",
      "expected_behavior": [
        "Provides complete manifest.json",
        "Uses correct donut chart UID (sap.viz.ext.donut)",
        "Includes measures and dimensions",
        "Includes feeds section",
        "References chart-types-reference.md"
      ]
    },
    {
      "id": "ic-002",
      "skill": "ui5-integration-cards",
      "prompt": "My analytical card shows 'No data to display' but the data URL returns valid JSON",
      "expected_behavior": [
        "Checks sap.card/data/path",
        "Checks content/data/path override",
        "Suggests testing URL in browser",
        "Provides troubleshooting checklist"
      ]
    },
    {
      "id": "ic-003",
      "skill": "ui5-integration-cards",
      "prompt": "Set up Configuration Editor for my card with admin persona",
      "expected_behavior": [
        "Shows dt/Configuration.js structure",
        "Explains persona design (Administrator)",
        "Covers manifest-editor synchronization",
        "Provides validation patterns"
      ]
    }
  ]
}
